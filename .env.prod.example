# Django Settings
SECRET_KEY=generate-a-secure-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,your-vps-ip,localhost,127.0.0.1

# Database Configuration (EXTERNAL CONNECTION STRING)
# Note: Since we are not using a local DB service, ensure this URL is accessible from the VPS.
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://user:password@external-host:5432/dbname

# Site Configuration
SITE_ID=1

# Email Configuration (Example using SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=https://yourdomain.com/api/v1/auth/google/callback/

# Supabase Configuration (if used in prod)
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key
