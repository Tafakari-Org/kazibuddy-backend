# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database_name

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_CALLBACK_URL=https://your-domain.com/api/v1/auth/google/callback/

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Django Configuration
SECRET_KEY=your-django-secret-key
DEBUG=False
ALLOWED_HOSTS=https://your-frontend-domain.com
SITE_ID=1

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.com

# CORS Configuration
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000
